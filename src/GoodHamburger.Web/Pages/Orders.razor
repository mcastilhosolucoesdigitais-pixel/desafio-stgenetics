@page "/orders"
@inject ApiClient Api

<PageTitle>Pedidos — Good Hamburger</PageTitle>

<h1 class="mb-4">Pedidos</h1>

<div class="row g-4">
    <!-- Formulário de novo pedido -->
    <div class="col-md-4">
        <div class="card shadow-sm">
            <div class="card-header bg-warning text-dark fw-bold">Novo Pedido</div>
            <div class="card-body">

                @if (_menuLoading)
                {
                    <p><em>Carregando cardápio...</em></p>
                }
                else
                {
                    <h6 class="mt-2">🥪 Sanduíche <small class="text-muted">(obrigatório)</small></h6>
                    @foreach (var item in _sandwiches)
                    {
                        <div class="form-check">
                            <input class="form-check-input" type="radio"
                                   name="sandwich" id="s@(item.Id)"
                                   checked="@(_selectedSandwichId == item.Id)"
                                   @onchange="() => _selectedSandwichId = item.Id" />
                            <label class="form-check-label" for="s@(item.Id)">
                                @item.Name — @item.Price.ToString("C", _ptBR)
                            </label>
                        </div>
                    }

                    <h6 class="mt-3">🍟 Acompanhamentos <small class="text-muted">(opcional)</small></h6>
                    @foreach (var item in _sides)
                    {
                        <div class="form-check">
                            <input class="form-check-input" type="checkbox"
                                   id="side@(item.Id)"
                                   checked="@_selectedSides.Contains(item.Id)"
                                   @onchange="e => ToggleSide(item.Id, (bool)e.Value!)" />
                            <label class="form-check-label" for="side@(item.Id)">
                                @item.Name — @item.Price.ToString("C", _ptBR)
                            </label>
                        </div>
                    }

                    @if (_formErrors.Count > 0)
                    {
                        <div class="alert alert-danger mt-3 p-2">
                            <ul class="mb-0 ps-3">
                                @foreach (var err in _formErrors)
                                {
                                    <li>@err</li>
                                }
                            </ul>
                        </div>
                    }

                    <button class="btn btn-warning w-100 mt-3 fw-bold"
                            @onclick="CreateOrderAsync" disabled="@_submitting">
                        @(_submitting ? "Enviando..." : "Fazer Pedido")
                    </button>
                }
            </div>
        </div>
    </div>

    <!-- Lista de pedidos -->
    <div class="col-md-8">
        <div class="d-flex justify-content-between align-items-center mb-3">
            <h5 class="mb-0">Pedidos realizados</h5>
            <button class="btn btn-outline-secondary btn-sm" @onclick="LoadOrdersAsync">↻ Atualizar</button>
        </div>

        <!-- Busca por ID -->
        <div class="input-group mb-3">
            <input type="number" class="form-control" placeholder="Buscar por ID do pedido..."
                   value="@_searchId"
                   @oninput="OnSearchInput"
                   @onkeydown="OnSearchKeyDown" min="1" />
            <button class="btn btn-outline-primary" @onclick="SearchOrderAsync" disabled="@(_searchId is null)">
                Buscar
            </button>
            @if (_searchResult is not null || _searchError is not null)
            {
                <button class="btn btn-outline-secondary" @onclick="ClearSearch">Limpar</button>
            }
        </div>

        @if (_searchError is not null)
        {
            <div class="alert alert-warning py-2">@_searchError</div>
        }
        else if (_searchResult is not null)
        {
            <div class="alert alert-success py-2 mb-3">
                Exibindo resultado da busca — <button class="btn btn-link btn-sm p-0" @onclick="ClearSearch">ver todos</button>
            </div>
            <div class="card mb-3 shadow-sm border-primary">
                @OrderCard(_searchResult)
            </div>
        }
        else if (_ordersLoading)
        {
            <p><em>Carregando pedidos...</em></p>
        }
        else if (_orders.Count == 0)
        {
            <div class="alert alert-info">Nenhum pedido registrado ainda.</div>
        }
        else
        {
            @foreach (var order in _orders)
            {
                <div class="card mb-3 shadow-sm">
                    @OrderCard(order)
                </div>
            }
        }
    </div>
</div>

@code {
    private bool _menuLoading = true;
    private bool _ordersLoading = true;
    private bool _submitting;
    private int? _selectedSandwichId;
    private readonly HashSet<int> _selectedSides = [];
    private List<GoodHamburger.Web.Models.MenuItemModel> _sandwiches = [];
    private List<GoodHamburger.Web.Models.MenuItemModel> _sides = [];
    private List<GoodHamburger.Web.Models.OrderModel> _orders = [];
    private List<string> _formErrors = [];

    private int? _searchId;
    private GoodHamburger.Web.Models.OrderModel? _searchResult;
    private string? _searchError;

    private static readonly System.Globalization.CultureInfo _ptBR =
        System.Globalization.CultureInfo.GetCultureInfo("pt-BR");

    protected override async Task OnInitializedAsync()
    {
        await Task.WhenAll(LoadMenuAsync(), LoadOrdersAsync());
    }

    private async Task LoadMenuAsync()
    {
        try
        {
            var items = await Api.GetMenuAsync() ?? [];
            _sandwiches = items.Where(i => i.Category == "Sandwich").ToList();
            _sides      = items.Where(i => i.Category == "Side").ToList();
        }
        finally { _menuLoading = false; }
    }

    private async Task LoadOrdersAsync()
    {
        _ordersLoading = true;
        try { _orders = await Api.GetOrdersAsync() ?? []; }
        finally { _ordersLoading = false; }
    }

    private void ToggleSide(int id, bool add)
    {
        if (add) _selectedSides.Add(id);
        else _selectedSides.Remove(id);
    }

    private async Task CreateOrderAsync()
    {
        _formErrors.Clear();

        if (_selectedSandwichId is null)
        {
            _formErrors.Add("Selecione um sanduíche.");
            return;
        }

        _submitting = true;
        try
        {
            var ids = new List<int> { _selectedSandwichId.Value };
            ids.AddRange(_selectedSides);

            var (order, errors) = await Api.CreateOrderAsync(ids);

            if (errors is { Count: > 0 })
            {
                _formErrors = errors;
                return;
            }

            _selectedSandwichId = null;
            _selectedSides.Clear();
            await LoadOrdersAsync();
        }
        finally { _submitting = false; }
    }

    private async Task DeleteOrderAsync(int id)
    {
        await Api.DeleteOrderAsync(id);
        if (_searchResult?.Id == id) ClearSearch();
        await LoadOrdersAsync();
    }

    private async Task SearchOrderAsync()
    {
        if (_searchId is null) return;
        _searchResult = null;
        _searchError = null;
        var (order, error) = await Api.GetOrderByIdAsync(_searchId.Value);
        if (order is not null) _searchResult = order;
        else _searchError = error;
    }

    private async Task OnSearchInput(ChangeEventArgs e)
    {
        var raw = e.Value?.ToString();
        if (string.IsNullOrWhiteSpace(raw))
        {
            _searchId = null;
            ClearSearch();
            await LoadOrdersAsync();
        }
        else if (int.TryParse(raw, out var id))
        {
            _searchId = id;
        }
    }

    private async Task OnSearchKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") await SearchOrderAsync();
    }

    private void ClearSearch()
    {
        _searchId = null;
        _searchResult = null;
        _searchError = null;
    }

    private RenderFragment OrderCard(GoodHamburger.Web.Models.OrderModel order) =>
        @<div>
            <div class="card-header d-flex justify-content-between align-items-center">
                <span class="fw-bold">Pedido #@order.Id</span>
                <button class="btn btn-outline-danger btn-sm"
                        @onclick="() => DeleteOrderAsync(order.Id)">
                    Remover
                </button>
            </div>
            <div class="card-body">
                <ul class="list-unstyled mb-2">
                    @foreach (var item in order.Items)
                    {
                        <li>@item.Name <span class="text-muted">@item.Price.ToString("C", _ptBR)</span></li>
                    }
                </ul>
                <hr class="my-1" />
                <div class="d-flex justify-content-between small text-muted">
                    <span>Subtotal</span><span>@order.Subtotal.ToString("C", _ptBR)</span>
                </div>
                @if (order.Discount > 0)
                {
                    <div class="d-flex justify-content-between small text-success">
                        <span>Desconto (@((order.DiscountPercent * 100).ToString("0"))%)</span>
                        <span>-@order.Discount.ToString("C", _ptBR)</span>
                    </div>
                }
                <div class="d-flex justify-content-between fw-bold">
                    <span>Total</span><span>@order.Total.ToString("C", _ptBR)</span>
                </div>
            </div>
        </div>;
}
