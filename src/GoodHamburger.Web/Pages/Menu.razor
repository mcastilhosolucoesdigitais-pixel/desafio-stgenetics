@page "/menu"
@inject ApiClient Api

<PageTitle>Cardápio — Good Hamburger</PageTitle>

<h1 class="mb-4">Cardápio</h1>

@if (_loading)
{
    <p><em>Carregando cardápio...</em></p>
}
else if (_error is not null)
{
    <div class="alert alert-danger">@_error</div>
}
else
{
    @foreach (var group in _groups)
    {
        <h4 class="mt-4">@CategoryLabel(group.Key)</h4>
        <div class="row g-3 mb-3">
            @foreach (var item in group.Value)
            {
                <div class="col-sm-6 col-md-4 col-lg-3">
                    <div class="card h-100 shadow-sm">
                        <div class="card-body d-flex flex-column justify-content-between">
                            <h5 class="card-title">@item.Name</h5>
                            <span class="fs-5 fw-semibold text-success">
                                @item.Price.ToString("C", _ptBR)
                            </span>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
}

@code {
    private bool _loading = true;
    private string? _error;
    private Dictionary<string, List<GoodHamburger.Web.Models.MenuItemModel>> _groups = [];
    private static readonly System.Globalization.CultureInfo _ptBR =
        System.Globalization.CultureInfo.GetCultureInfo("pt-BR");

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var items = await Api.GetMenuAsync();
            _groups = (items ?? [])
                .GroupBy(i => i.Category)
                .ToDictionary(g => g.Key, g => g.ToList());
        }
        catch
        {
            _error = "Não foi possível carregar o cardápio. Verifique se a API está em execução.";
        }
        finally
        {
            _loading = false;
        }
    }

    private static string CategoryLabel(string category) => category switch
    {
        "Sandwich" => "🥪 Sanduíches",
        "Side"     => "🍟 Acompanhamentos",
        _          => category
    };
}
